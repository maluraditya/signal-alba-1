# Required for AI-generated company briefs. Keep this server-side.
GEMINI_API_KEY=

# Required for live country context. Create a free key at restcountries.com.
REST_COUNTRIES_API_KEY=

# Optional. Raises GitHub's public API limit from 60 to 5,000 requests/hour.
GITHUB_TOKEN=

# Public canonical URL after deployment, for example https://signal.vercel.app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public source URL shown in the header after the repository is created.
NEXT_PUBLIC_SOURCE_URL=

# Optional Gemini model override.
GEMINI_MODEL=gemini-2.5-flash
